# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=fastapi_db

DATABASE_URL=postgresql://postgres:change_me_db_password@db:5432/fastapi_db
TEST_DATABASE_URL=postgresql://postgres:change_me_db_password@db:5432/fastapi_test_db

# ── JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=replace_with_at_least_32_random_chars
JWT_REFRESH_SECRET_KEY=replace_with_a_different_32_random_chars

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Redis (leave blank to disable token blacklisting) ────────────────────────
REDIS_URL=

# ── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password
